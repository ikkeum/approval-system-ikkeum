NEXT_PUBLIC_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>

# 사이트 URL (초대 메일의 redirect 용). 배포 시 Vercel 도메인으로.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 서버 전용. Edge Function / Route Handler / 서버 액션에서만 사용. NEXT_PUBLIC_ prefix 절대 금지.
# admin 초대·멤버 수정은 이 키로 RLS 우회 실행.
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>

# Google Chat Webhook (Day 5에 사용)
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/...

# Google Calendar 연차 자동 등록
# 1) GCP에서 서비스 계정 생성 → JSON 키 발급
# 2) 서비스 계정에서 도메인 전체 위임(DwD) 활성화 → Client ID 복사
# 3) GWS 어드민 → 보안 → API 제어 → 도메인 전체 위임 관리에서
#    Client ID + scope `https://www.googleapis.com/auth/calendar` 등록
# 4) GOOGLE_IMPERSONATE_USER에 캘린더 편집 권한이 있는 내부 사용자 이메일 지정
# 5) Vercel에 아래 환경 변수 등록 (PRIVATE_KEY는 \n 이스케이프된 한 줄)
GOOGLE_SERVICE_ACCOUNT_EMAIL=<service_account>@<project>.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_IMPERSONATE_USER=admin@idealkr.com
GOOGLE_CALENDAR_ID=c_3e6phcig7864ujf8d06l34ar9k@group.calendar.google.com
